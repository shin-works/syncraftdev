---
/**
 * /{lang}/ — Non-default language top pages
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProductSection from '../../components/ProductSection.astro';
import BlogSection from '../../components/BlogSection.astro';
import ContactSection from '../../components/ContactSection.astro';
import { t } from '../../i18n/utils';
import {
  blogLangs,
  nonDefaultBlogLangs,
  type Lang,
} from '../../i18n/translations';

export function getStaticPaths() {
  return nonDefaultBlogLangs.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Exclude<Lang, 'ja'> };
const alternateUrls = Object.fromEntries(
  blogLangs.map((code) => [code, code === 'ja' ? '/' : `/${code}/`]),
);
---

<BaseLayout
  title={t(lang, 'site.title')}
  description={t(lang, 'site.description')}
  lang={lang}
  canonicalUrl={`/${lang}/`}
  alternateUrls={alternateUrls}
  activeNav="hero"
  currentPath={`/${lang}/`}
>
  <Hero lang={lang} />
  <ProductSection lang={lang} />
  <BlogSection lang={lang} />
  <ContactSection lang={lang} />
</BaseLayout>
